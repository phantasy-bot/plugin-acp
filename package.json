{
  "name": "@phantasy/plugin-acp",
  "version": "2.0.1",
  "private": false,
  "description": "Virtuals Protocol ACP commerce plugin for Phantasy.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "phantasy.plugin.json"
  ],
  "sideEffects": false,
  "keywords": [
    "acp",
    "commerce",
    "jobs",
    "offerings"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/phantasy-bot/plugin-acp"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/phantasy-bot/plugin-acp",
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@phantasy/agent": "^2.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.9.2"
  },
  "phantasy": {
    "displayName": "Virtuals Protocol ACP",
    "category": "commerce",
    "tags": [
      "acp",
      "commerce",
      "jobs",
      "offerings"
    ],
    "workspace": "business",
    "extensionKind": "capability",
    "permissions": [
      "internet"
    ],
    "pluginDependencies": [
      {
        "plugin": "@phantasy/plugin-wallet"
      }
    ],
    "platforms": [
      "node"
    ],
    "productionReady": false,
    "adminSurface": {
      "tabId": "acp",
      "label": "Virtuals Protocol ACP",
      "section": "business",
      "workspace": "business",
      "kind": "generic",
      "keywords": [
        "acp",
        "commerce",
        "jobs",
        "offerings"
      ]
    },
    "configSchema": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        }
      }
    }
  }
}
